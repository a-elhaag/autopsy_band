# --- Model provider (OpenRouter, OpenAI-compatible) ---
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=sk-or-your-key-here

# App attribution headers sent to OpenRouter
APP_URL=http://localhost:8000
APP_NAME=Autopsy Band

# Per-agent model ids (OpenRouter slugs). Override any to taste.
MODEL_ANNOTATOR=anthropic/claude-3.5-sonnet
MODEL_VERIFIER=anthropic/claude-3.5-sonnet
MODEL_SCORER=anthropic/claude-3.5-sonnet
MODEL_RECONSTRUCTOR=anthropic/claude-3.5-sonnet
MODEL_APEX=anthropic/claude-3.5-sonnet
MODEL_ESCALATION=anthropic/claude-3.5-sonnet

# Max input chars accepted (agent.md: 5000, stateless)
MAX_INPUT_CHARS=5000

# --- Band SDK (real inter-agent transport) ---
# Set BAND_ENABLED=1 to route handoffs through the Band council instead of
# the in-process path. Requires the council process running (python -m app.band.run),
# the 6 agents registered (agent_config.yaml), and one shared chat room.
BAND_ENABLED=0
THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket
# Chat room all 6 agents + the initiator share:
BAND_CHAT_ID=
# API key the web app uses to post the initial request into the room
# (any registered agent/initiator key that is a room participant):
BAND_INITIATOR_API_KEY=
BAND_TIMEOUT=120
